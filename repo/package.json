{
  "name": "@byadsco/meta-ads-mcp",
  "version": "3.0.0",
  "description": "MCP server for Meta Ads (Facebook/Instagram) management - agency multi-account",
  "author": {
    "name": "Santiago Bastidas",
    "email": "dev@byads.co",
    "url": "https://byads.co"
  },
  "contributors": [
    {
      "name": "ByAds",
      "url": "https://byads.co"
    }
  ],
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "main": "dist/index.js",
  "bin": {
    "meta-ads-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "prepublishOnly": "npm run build && npm test",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js --transport stdio",
    "dev": "tsx src/index.ts",
    "dev:stdio": "tsx src/index.ts --transport stdio",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.5.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "jose": "^6.0.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "meta",
    "meta-ads",
    "meta-marketing-api",
    "facebook",
    "facebook-ads",
    "facebook-ads-api",
    "facebook-marketing-api",
    "instagram",
    "instagram-ads",
    "ads",
    "advertising",
    "marketing",
    "marketing-api",
    "campaigns",
    "agency",
    "multi-tenant",
    "claude",
    "anthropic",
    "ai-agent",
    "openai",
    "oauth",
    "firestore",
    "cloud-run",
    "typescript"
  ],
  "license": "MIT",
  "homepage": "https://github.com/byadsco/meta-ads-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/byadsco/meta-ads-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/byadsco/meta-ads-mcp/issues"
  }
}
