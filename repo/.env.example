# Meta Ads MCP Server Configuration
# ─────────────────────────────────────────────────────────────────
# Copy to `.env` and fill the values for your deployment.
# Never commit `.env` — it is gitignored.

# ── Public URL of this server (required in production) ─────────
# e.g. https://meta-ads-mcp-xxx.run.app or http://localhost:3000
SERVER_URL=

# ── Meta App credentials (required for OAuth login flow) ──────
# Create an App at developers.facebook.com → Add product "Facebook Login"
# Configure Valid OAuth Redirect URI: <SERVER_URL>/auth/meta/callback
META_APP_ID=
META_APP_SECRET=
# Optional override; auto-derived from SERVER_URL if absent
META_OAUTH_REDIRECT_URI=

# ── Allowlist (at least one source required when META_APP_ID is set) ──
# Only listed identities can complete the Meta login flow.
AUTH_ALLOWED_EMAILS=
AUTH_ALLOWED_DOMAINS=
AUTH_ALLOWED_FB_USER_IDS=

# ── Encryption & sessions ─────────────────────────────────────
# Used to encrypt Meta tokens at rest in Firestore (AES-256-GCM)
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Used to sign session cookies (>= 32 chars random)
# Generate with: openssl rand -base64 32
SESSION_COOKIE_SECRET=

# Used to sign MCP OAuth JWTs (>= 32 chars random)
# Generate with: openssl rand -hex 32
OAUTH_SECRET=

# ── Firestore (where encrypted tokens live) ──────────────────
# Defaults to GOOGLE_CLOUD_PROJECT when running on GCP.
# For local dev, point FIRESTORE_EMULATOR_HOST to the emulator.
FIRESTORE_PROJECT_ID=
# FIRESTORE_EMULATOR_HOST=localhost:8085

# ── Legacy / single-tenant fallbacks (optional) ──────────────
# If set, used as a fallback when no per-user token is available.
META_ACCESS_TOKEN=
# Multi-token JSON: {"agency_a":"EAA...","agency_b":"EAA..."}
META_TOKENS=
# Service-to-service API key (skips OAuth entirely)
MCP_API_KEY=

# ── Server settings ──────────────────────────────────────────
META_API_VERSION=v22.0
PORT=3000
LOG_LEVEL=info
NODE_ENV=production
