generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdInsight {
  id               Int      @id @default(autoincrement())
  accountId        String
  date             String
  accountName      String
  reach            Int      @default(0)
  impressions      Int      @default(0)
  clicks           Int      @default(0)
  spend            Float    @default(0)
  addToCart        Int      @default(0)
  initiateCheckout Int      @default(0)
  purchases        Int      @default(0)
  purchaseValue    Float    @default(0)
  cpc              Float    @default(0)
  ctr              Float    @default(0)
  atcRate          Float    @default(0)
  checkoutRate     Float    @default(0)
  cpp              Float    @default(0)
  roas             Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([accountId, date])
}

model Setting {
  key   String @id
  value String
}

model AccountMapping {
  accountId   String   @id
  accountName String
  project     String?
  store       String?
  owner       String?
  updatedAt   DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("member") // "admin" or "member"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invitation {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  token     String   @unique
  role      String   @default("member")
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Store {
  id             Int         @id @default(autoincrement())
  name           String      @unique
  shopline_token String?
  shopify_token  String?
  domain         String?
  visitors       Int         @default(0)
  accounts       AdAccount[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model MetaAccountMonitoring {
  accountId     String   @id
  accountName   String?
  status        Int?
  spendCap      Float?
  amountSpent   Float?
  balance       Float?
  currency      String?
  timezone      String?
  updatedAt     DateTime @updatedAt
}

model AdAccount {
  id              Int      @id @default(autoincrement())
  fb_account_id   String   @unique
  fb_account_name String?
  fb_access_token String?
  storeId         Int
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Product {
  id          String   @id
  storeId     Int
  name        String
  sku         String
  category    String
  inventory   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id          String   @id
  storeId     Int
  productId   String
  revenue     Float    @default(0)
  profit      Float    @default(0)
  refunded    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Campaign {
  id          String   @id
  accountId   String
  name        String
  region      String?
  status      String?
}

model AdSet {
  id          String   @id
  campaignId  String
  accountId   String
  name        String
}

model Ad {
  id          String   @id
  adsetId     String
  campaignId  String
  accountId   String
  name        String
  creativeId  String?
}

model AdCreative {
  id          String   @id
  storeId     Int?
  name        String
  type        String   // IMAGE, VIDEO, CAROUSEL
  hookRate    Float    @default(0)
}

model ProductPerformanceDaily {
  id               Int      @id @default(autoincrement())
  date             String
  storeId          Int
  productId        String
  productName      String
  sku              String
  category         String
  revenue          Float    @default(0)
  orders           Int      @default(0)
  profit           Float    @default(0)
  adSpend          Float    @default(0)
  productRoas      Float    @default(0)
  profitRoas       Float    @default(0)
  ctr              Float    @default(0)
  cpc              Float    @default(0)
  cpm              Float    @default(0)
  frequency        Float    @default(0)
  refundRate       Float    @default(0)
  inventory        Int      @default(0)
  topRegion        String?
  topCampaign      String?
  topCreative      String?
  aiRiskStatus     String?
  trendStatus      String?
  aiSuggestion     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([storeId, productId, date])
}

model CreativePerformanceDaily {
  id               Int      @id @default(autoincrement())
  date             String
  storeId          Int
  creativeId       String
  creativeName     String
  type             String
  spend            Float    @default(0)
  purchases        Int      @default(0)
  revenue          Float    @default(0)
  roas             Float    @default(0)
  ctr              Float    @default(0)
  cpc              Float    @default(0)
  cpm              Float    @default(0)
  frequency        Float    @default(0)
  hookRate         Float    @default(0)
  aiRiskStatus     String?
  trendStatus      String?
  aiSuggestion     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([storeId, creativeId, date])
}
