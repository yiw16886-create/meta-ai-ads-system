generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdInsight {
  id               Int      @id @default(autoincrement())
  accountId        String
  date             String
  accountName      String
  reach            Int      @default(0)
  impressions      Int      @default(0)
  clicks           Int      @default(0)
  spend            Float    @default(0)
  addToCart        Int      @default(0)
  initiateCheckout Int      @default(0)
  purchases        Int      @default(0)
  purchaseValue    Float    @default(0)
  cpc              Float    @default(0)
  ctr              Float    @default(0)
  atcRate          Float    @default(0)
  checkoutRate     Float    @default(0)
  cpp              Float    @default(0)
  roas             Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([accountId, date])
}

model Setting {
  key   String @id
  value String
}

model AccountMapping {
  accountId   String   @id
  accountName String
  project     String?
  store       String?
  owner       String?
  updatedAt   DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("member") // "admin" or "member"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizations UserOrganization[]
  workspaces    UserWorkspace[]
  auditLogs     AuditLog[]
}

model Invitation {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  token     String   @unique
  role      String   @default("member")
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Store {
  id             Int         @id @default(autoincrement())
  name           String      @unique
  shopline_token String?
  shopify_token  String?
  domain         String?
  visitors       Int         @default(0)
  accounts       AdAccount[]
  workspaceId    String?
  workspace      Workspace?  @relation(fields: [workspaceId], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model MetaAccountMonitoring {
  accountId     String   @id
  accountName   String?
  status        Int?
  spendCap      Float?
  amountSpent   Float?
  balance       Float?
  currency      String?
  timezone      String?
  updatedAt     DateTime @updatedAt
}

model AdAccount {
  id              Int      @id @default(autoincrement())
  fb_account_id   String   @unique
  fb_account_name String?
  fb_access_token String?
  workspaceId     String?
  workspace       Workspace? @relation(fields: [workspaceId], references: [id])
  storeId         Int
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// SaaS Multi-tenancy Extensions

model Organization {
  id          String   @id @default(cuid())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Subscription / Billing Tier
  plan        PlanTier @default(FREE)
  stripeId    String?

  users       UserOrganization[]
  workspaces  Workspace[]
  auditLogs   AuditLog[]
}

enum PlanTier {
  FREE
  PRO
  ENTERPRISE
}

model Workspace {
  id             String       @id @default(cuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  users          UserWorkspace[]
  stores         Store[]
  adAccounts     AdAccount[]
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum WorkspaceRole {
  ADMIN
  OPERATOR
  VIEWER
}

model UserOrganization {
  userId         Int
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           OrgRole      @default(MEMBER)
  
  @@id([userId, organizationId])
}

model UserWorkspace {
  userId      Int
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role        WorkspaceRole @default(VIEWER)

  @@id([userId, workspaceId])
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         Int?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  action         String
  resourceType   String
  resourceId     String?
  details        String?      // Storing JSON string for compatibility
  createdAt      DateTime     @default(now())
}

