# Optional one-time administrator bootstrap (server-side only)
# Configure both values together, deploy once, then remove ADMIN_INITIAL_PASSWORD.
ADMIN_EMAIL=
ADMIN_INITIAL_PASSWORD=

# Meta API
META_ACCESS_TOKEN=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CONFIG_ID=

# JWT Secret (required, unique, at least 32 characters)
JWT_SECRET=

# Database (Use PostgreSQL string like Vercel Postgres or Supabase)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# AI Studio
GEMINI_API_KEY=
APP_URL=
